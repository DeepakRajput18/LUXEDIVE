{
  "name": "luxedive",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "360": "cd backend/generate_360 && python -m venv venv && source venv/bin/activate && node render_worker.js & python worker.py",
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "dev:frontend": "vite",
    "dev": "concurrently --kill-others \"npm run supabase\" \"node backend/server.js\" \"npm run dev:frontend -- --open\"",
    "dev:ps": "powershell -ExecutionPolicy Bypass -File scripts/start-all.ps1",
    "start": "npm run dev",
    "stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-all.ps1",
    "frontend": "npm run dev:frontend",
    "backend": "cd backend && python app.py",
    "supabase": "supabase start",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase db push",
    "logs": "docker logs -f supabase_db",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/supabase-js": "^2.91.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react-datepicker": "^6.2.0",
    "@types/three": "^0.183.1",
    "autoprefixer": "^10.4.23",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^7.3.0",
    "framer-motion": "^12.29.2",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.563.0",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.71.1",
    "react-router-dom": "^7.13.0",
    "recharts": "^2.12.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "three": "^0.183.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.0.0"
  }
}
